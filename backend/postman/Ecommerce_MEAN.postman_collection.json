            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const runId = String(Date.now());",
                  "pm.environment.set('runId', runId);",
                  "pm.environment.set('guestId', `postman-guest-${runId}`);",
                  "pm.environment.set('customerEmail', `customer.postman+${runId}@example.com`);",
                  "pm.environment.set('sellerEmail', `seller.postman+${runId}@example.com`);",
                  "pm.environment.set('adminEmail', `admin.postman+${runId}@example.com`);",
                  "pm.environment.set('adminTargetEmail', `target.postman+${runId}@example.com`);",
                  "pm.environment.set('sellerCandidateEmail', `sellercandidate.postman+${runId}@example.com`);",
                  "pm.environment.set('googleEmail', `google.postman+${runId}@example.com`);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/health"
          }
        },
